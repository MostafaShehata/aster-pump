# Aster Pump Aftercare root ignore file.
# This repository contains multiple local services, so this file covers
# frontend, Python, Docker, generated assets, and local machine files.

# Local secrets and environment overrides
.env
.env.*
!.env.example
*.local

# Node / React / Vite
node_modules/
dist/
build/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/
.venv/
venv/
env/

# FastEmbed / model caches that may appear during local runs
.fastembed_cache/
.cache/

# Docker and runtime output
*.log
*.pid
tmp/
temp/

# Generated demo artifacts
/asterpump_x17_user_guide.pdf
/test-images/

# Backend documentation assets are part of the demo and should be committed:
# - aster-pump-aftercare-backend/docs/*.txt
# - aster-pump-aftercare-backend/docs/*.pdf
# - aster-pump-aftercare-backend/docs/assets/**

# OS and editor files
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo

# PowerShell and shell history/local output
*.ps1xml
*.clixml
*.stackdump
